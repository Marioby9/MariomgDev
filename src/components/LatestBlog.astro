---
import BLOG_POSTS from "./BlogList";

const [latestPost] = BLOG_POSTS;
---

{
  latestPost && (
    <a href={`/blog/${latestPost.slug}`} class="block group">
      <article class="rounded-2xl border border-white/10 bg-white/[0.03] p-5 md:p-6 transition hover:bg-white/[0.06] hover:border-white/20">
        <div class="flex flex-wrap items-center gap-2 mb-3">
          <span class={`rounded-full text-xs px-3 py-1 ${latestPost.category.class}`}>
            {latestPost.category.name}
          </span>
          <span class="text-xs text-white/55">{latestPost.readTime}</span>
        </div>

        <h3 class="text-2xl font-semibold text-yellow-200 mb-2 group-hover:text-yellow-100 transition">{latestPost.title}</h3>
        <p class="text-base md:text-lg text-white/85">{latestPost.description}</p>
      </article>
    </a>
  )
}
