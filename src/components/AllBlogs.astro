---
import BLOG_POSTS from "./BlogList";
---

<div class="flex flex-col gap-y-8">
  {
    BLOG_POSTS.map((post) => (
      <article class="rounded-2xl border border-white/10 bg-white/[0.03] p-5 md:p-6">
        <div class="flex flex-wrap items-center gap-2 mb-3">
          <span class={`rounded-full text-xs px-3 py-1 ${post.category.class}`}>
            {post.category.name}
          </span>
          <span class="text-xs text-white/55">{post.publishedAt}</span>
          <span class="text-xs text-white/40">•</span>
          <span class="text-xs text-white/55">{post.readTime}</span>
        </div>

        <h3 class="text-2xl font-semibold text-yellow-200 mb-2">{post.title}</h3>
        <p class="text-base md:text-lg text-white/85 mb-4">{post.description}</p>

        <h4 class="text-sm uppercase tracking-wide text-white/60 mb-2">Puntos clave</h4>
        <ul class="space-y-2 text-sm md:text-base text-white/75">
          {
            post.highlights.map((highlight) => (
              <li class="flex gap-2">
                <span class="text-sky-200">•</span>
                <span>{highlight}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-5">
          <a
            href={`/blog/${post.slug}`}
            class="inline-flex rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-white/85 hover:bg-white/10 transition"
          >
            Leer artículo completo
          </a>
        </div>
      </article>
    ))
  }
</div>
